# Runtime Classifier (photography example) — config
# Copy this file to .env and fill in your API key.
# Defaults below match what photography.md ships with; override anything you want.

# ============================================
# REQUIRED
# ============================================

# OpenAI API key — used by the photography example for image generation
# (gpt-image-2) and vision-model scoring (gpt-4o). These are the defaults
# the example was tested against; swap to any prompt-driven generator
# (image/video/audio/text) and any evaluator that fits your output medium.
# Get an OpenAI key at https://platform.openai.com.
OPENAI_API_KEY=sk-proj-...

# ============================================
# OPTIONAL — overrides for photography.md defaults
# ============================================

# Generation model (any prompt-driven generator — image, video, audio, etc.)
# IMAGE_MODEL=gpt-image-2
# IMAGE_SIZE=1536x1024
# IMAGE_QUALITY=high

# Evaluator (any model that can score output against rules — vision/text/audio)
# VISION_MODEL=gpt-4o

# Pass threshold (combined score)
# SCORE_THRESHOLD=0.75
